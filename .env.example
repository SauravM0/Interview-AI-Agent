# ═══════════════════════════════════════════════════════════════
#  Interview AI Agent — Environment Variables
#  Copy this to .env (backend) and dashboard/.env.local (frontend)
# ═══════════════════════════════════════════════════════════════

# ── Backend (.env in project root) ────────────────────────────

# Security
API_SECRET_TOKEN=change_this_to_a_long_random_string_min_32_chars

# CORS: comma-separated frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── LiveKit ────────────────────────────────────────────────────
# Local Docker dev:
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
# LiveKit Cloud (free Build tier — 1000 agent min/mo):
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=APIxxxxxxxxxx
# LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq (free LLM + STT — get key at console.groq.com, no credit card) ──────
GROQ_API_KEY=gsk_your_key_here

# Optional: add more keys for multiplied free quota (rotate on rate limit)
# GROQ_API_KEY_2=gsk_second_key
# GROQ_API_KEY_3=gsk_third_key

# LLM model for interview agent (primary — 1,000 calls/day free)
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# LLM model fallback (14,400 calls/day free — auto-switches when primary exhausted)
GROQ_LLM_FALLBACK_MODEL=llama-3.1-8b-instant

# STT model for transcription (2,000 calls/day free)
GROQ_STT_MODEL=whisper-large-v3-turbo

# LLM model for post-interview evaluation (separate quota from agent)
GROQ_EVAL_MODEL=llama-3.3-70b-versatile

# TTS is handled by Kokoro (free, no key needed)

# ── Database ───────────────────────────────────────────────────
# Leave empty to use local SQLite (good for dev)
# DATABASE_URL=

# Supabase PostgreSQL (free 500MB, permanent):
# 1. Create project at https://supabase.com
# 2. Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Email (optional — skip for demo) ──────────────────────────
# EMAIL_ADDRESS=your@gmail.com
# EMAIL_PASSWORD=your_gmail_app_password
# SMTP_SERVER=smtp.gmail.com

# ─────────────────────────────────────────────────────────────
#  Frontend (dashboard/.env.local)
# ─────────────────────────────────────────────────────────────

# URL of your deployed API server
NEXT_PUBLIC_API_URL=http://localhost:8000

# LiveKit server URL (must be accessible from the browser)
# Local: ws://localhost:7880
# Cloud: wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# LiveKit API keys (server-side only — for Next.js token route)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
